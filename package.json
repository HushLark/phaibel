{
  "name": "phaibel",
  "version": "5.2.35",
  "description": "AI personal agent that dynamically assembles executable processes from composable code blocks — powered by FeralCCF",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./dist/*": "./dist/*"
  },
  "bin": {
    "phaibel": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "todo",
    "notes",
    "personal-assistant",
    "openai",
    "anthropic",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/clift-labs/phaibel.git"
  },
  "license": "MIT",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && cp src/phaibel.txt dist/phaibel.txt && cp src/service/web-client.html dist/service/web-client.html && cp src/service/mobile-client.html dist/service/mobile-client.html && cp src/service/productve.html dist/service/productve.html && cp src/service/Assistant.html dist/service/Assistant.html && mkdir -p dist/feral/tier1 && cp src/feral/tier1/*.json dist/feral/tier1/",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude='tests/integration/**'",
    "test:watch": "vitest --exclude='tests/integration/**'",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "eval": "tsx evals/run-eval.ts",
    "eval:loop": "tsx evals/loop.ts",
    "eval:compare": "tsx evals/compare.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@gclift/cxms": "^2.1.18",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.2.12",
    "marked": "^17.0.2",
    "node-ical": "^0.25.4",
    "openai": "^6.17.0",
    "ora": "^8.0.1",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
